# =============================================================================
# Ghostty 設定 — macOS / 日本語 / tmux 最適化
# =============================================================================

# =============================================================================
# フォント
# =============================================================================
# Nerd Font を指定（例: JetBrainsMono Nerd Font）
# brew install --cask font-jetbrains-mono-nerd-font でインストール
font-family = JetBrainsMono Nerd Font
font-size = 14

# 日本語フォントフォールバック（英字と日本語で別フォントを使う場合）
# font-family-fallback = "Hiragino Sans"

# 日本語でリガチャが誤動作するフォントの場合は以下で無効化
# （例: BIZ UDGothic で「ます」→「〼」になる問題の回避）
font-feature = -liga
font-feature = -dlig
font-feature = -calt

# =============================================================================
# CJK 文字幅の調整
# （フォントによって全角文字が半角扱いされる場合に設定）
# =============================================================================
# 日本語・中国語・韓国語のコードポイント範囲を2カラム扱いに
# font-codepoint-map = U+3000-U+9FFF=源ノ角ゴシック JP

# =============================================================================
# 外観
# =============================================================================
theme = catppuccin-mocha

# 透過（0.0〜1.0、1.0で不透明）
background-opacity = 0.95
# ぼかし（透過と組み合わせて使用、macOS のみ）
background-blur-radius = 20

# ウィンドウパディング
window-padding-x = 12
window-padding-y = 8

# macOS タイトルバーをターミナルに溶け込ませる
macos-titlebar-style = transparent

# =============================================================================
# カーソル
# =============================================================================
cursor-style = bar              # block / bar / underline
cursor-style-blink = true

# =============================================================================
# シェル統合
# =============================================================================
shell-integration = zsh         # zsh 統合を有効化
shell-integration-features = cursor,sudo,title

# =============================================================================
# tmux 併用時の設定
# =============================================================================
# tmux 内でも Ghostty の独自機能（ハイパーリンクなど）を使えるようにする
term = xterm-256color
# ※ SSH 先で xterm-ghostty が認識されない問題を回避するため
#   tmux.conf 側で TERM を上書きする設定と合わせて使う

# =============================================================================
# キーバインド
# =============================================================================
# Cmd+Enter でフルスクリーン
keybind = cmd+enter=toggle_fullscreen

# Shift+Enter を tmux / Claude Code に送る（改行コード）
keybind = shift+enter=text:\n

# Cmd+, で設定ファイルを開く
keybind = cmd+comma=open_config

# =============================================================================
# クリップボード
# =============================================================================
clipboard-read  = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true

# =============================================================================
# マウス
# =============================================================================
mouse-hide-while-typing = true

# =============================================================================
# 通知
# =============================================================================
# 長時間かかるコマンドが終了したときに通知
desktop-notifications = true

# =============================================================================
# スクロール
# =============================================================================
scrollback-limit = 10000

# =============================================================================
# macOS 固有
# =============================================================================
# Option キーを Meta キーとして使う（zsh の Alt+. など）
macos-option-as-alt = left      # left のみ Meta、right は特殊文字入力
